# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Google Calendar API
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Volitelně můžete napevno zadat ID sdíleného kalendáře (např. EFko), jinak se aplikace pokusí kalendář EFko najít automaticky
# GOOGLE_CALENDAR_ID=tvoje_id@group.calendar.google.com
